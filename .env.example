# Database
DATABASE_URL=postgresql://user:password@host:5432/monitor_agent

# Anthropic (Claude agent)
ANTHROPIC_API_KEY=sk-ant-...

# Vercel (redeploy + logs)
VERCEL_TOKEN=...

# Firebase Admin (reads hub_clients for dynamic client list)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_ID=

# Notifications — email
RESEND_API_KEY=
NOTIFY_EMAIL=liam.arzac@gmail.com
FROM_EMAIL=Nichos Monitor <onboarding@resend.dev>

# Notifications — WhatsApp (Twilio, critical incidents only)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
NOTIFY_WHATSAPP=whatsapp:+9720557719141

# Server
PORT=8080

# Agent controls
MONITOR_AGENT_MODEL=claude-haiku-4-5-20251001
MONITOR_AGENT_ENABLED=true
MONITOR_AGENT_MAX_PER_HOUR=10
MONITOR_CONCURRENCY=10
